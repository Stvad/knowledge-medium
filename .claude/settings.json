{
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(pnpm run *)",
      "Bash(pnpm compile *)",
      "Bash(pnpm test *)",
      "Bash(pnpm vitest:*)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(pnpm agent ping:*)",
      "Bash(pnpm agent status:*)",
      "Bash(pnpm agent profiles:*)",
      "Bash(pnpm agent runtime-summary:*)",
      "Bash(pnpm agent describe-runtime:*)",
      "Bash(pnpm agent health:*)",
      "Bash(pnpm agent get-block:*)",
      "Bash(pnpm agent subtree:*)",
      "Bash(pnpm agent types:*)",
      "Bash(pnpm agent sql all:*)",
      "Bash(pnpm agent sql get:*)",
      "Bash(pnpm agent sql optional:*)"
    ],
    "ask": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/check-staged-pii.mjs\"",
            "if": "Bash(git *)",
            "statusMessage": "Scanning staged changes for PII…"
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/check-env-read.mjs\"",
            "statusMessage": "Checking for secret-file reads…"
          }
        ]
      }
    ]
  }
}
