{
  "name": "@knowledge-medium/agent-dispatch",
  "private": true,
  "version": "0.1.0",
  "description": "Dispatch note-graph triggers to local agent CLIs: backlink mentions, query-change watchers, durable graph lifecycle state, and optional channel delivery.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "km-agent-dispatch": "./dist/daemon.js",
    "km-agent-dispatch-channel-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -b && chmod +x ./dist/daemon.js ./dist/mcp.js"
  },
  "dependencies": {
    "@knowledge-medium/agent-cli": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  }
}
