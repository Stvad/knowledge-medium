{
  "name": "@knowledge-medium/agent-cli",
  "version": "0.2.0",
  "description": "CLI, local HTTP bridge, and graph MCP server for driving the Knowledge Medium app from local agents.",
  "keywords": [
    "cli",
    "agent",
    "claude",
    "knowledge-medium",
    "automation"
  ],
  "license": "MIT",
  "author": "Vlad Sitalo",
  "repository": {
    "type": "git",
    "url": "https://github.com/stvad/knowledge-medium.git",
    "directory": "packages/agent-cli"
  },
  "homepage": "https://github.com/stvad/knowledge-medium/tree/master/packages/agent-cli#readme",
  "bugs": {
    "url": "https://github.com/stvad/knowledge-medium/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "agent-cli": "./dist/cli.js",
    "kmagent": "./dist/cli.js",
    "kmagent-server": "./dist/server.js",
    "km-mcp": "./dist/mcp.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./server": "./dist/server.js",
    "./client": "./dist/client.js",
    "./config": "./dist/config.js",
    "./graph": "./dist/graph.js",
    "./mcpShared": "./dist/mcpShared.js",
    "./mcpServer": "./dist/mcpServer.js",
    "./mcp": "./dist/mcp.js",
    "./protocol": "./dist/protocol.js",
    "./subtreeOutline": "./dist/subtreeOutline.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/build-kernel-types.mjs && chmod +x ./dist/cli.js ./dist/server.js ./dist/mcp.js",
    "build:clean": "tsc -b --clean",
    "prepublishOnly": "yarn run build:clean && yarn run build"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "^7.0.0",
    "zod": "^4.0.0"
  }
}
