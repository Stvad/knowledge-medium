{
  "name": "@knowledge-medium/agent-cli",
  "version": "0.0.0",
  "description": "CLI + local HTTP bridge for driving the Knowledge Medium app from an agent (Claude/etc.). Pairs once with a browser tab, then forwards JSON commands over loopback.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "kmagent": "./dist/cli.js",
    "kmagent-server": "./dist/server.js"
  },
  "main": "./dist/cli.js",
  "exports": {
    ".": "./dist/cli.js",
    "./server": "./dist/server.js",
    "./config": "./dist/config.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && chmod +x ./dist/cli.js ./dist/server.js",
    "build:clean": "tsc -b --clean"
  },
  "devDependencies": {
    "@types/node": "*",
    "typescript": "*"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "zod": "^4.4.3"
  }
}
