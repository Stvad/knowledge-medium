{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.scripts.tsbuildinfo",
    // scripts run under Node (vite-node / tsx), so they need the Node globals
    // and `node:*` modules that the browser-oriented app config omits.
    "types": ["node"]
  },
  "include": ["scripts"],
  // scripts/bench/* was resurrected against the Layout B data layer (setup.ts
  // builds on @/data/test/createTestDb; the dead row-events-tail suite was
  // removed) and runs via `yarn bench [suite…]` (vite-node). It stays OUT of
  // the `tsc -b` gate on purpose: the bench imports the app's module graph
  // (createTestDb → staticDataExtensions → plugins), which is Vite-typed
  // (`import.meta.env`) and meant to be checked by the app project — not by
  // this Node-typed (`types: ["node"]`) scripts project, where it fails to
  // resolve. vite-node strips types and supplies import.meta.env at runtime.
  "exclude": ["scripts/bench"]
}
