  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "vite",
    "compile": "tsgo -b && pnpm run compile:post",
    "compile:tsc": "tsc -b && pnpm run compile:post",
    "compile:packages": "tsc -b packages/agent-cli packages/agent-dispatch && pnpm run compile:post",
    "compile:post": "node packages/agent-cli/scripts/build-kernel-types.mjs && chmod +x packages/agent-cli/dist/cli.js packages/agent-cli/dist/server.js packages/agent-cli/dist/mcp.js packages/agent-dispatch/dist/daemon.js packages/agent-dispatch/dist/mcp.js",
    "build": "pnpm run compile && vite build && vite build --config vite.sw.config.ts && vite-node scripts/inject-sw-build-id.ts",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --cache-strategy content",
    "preview": "vite preview",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:sync-config": "vite-node scripts/gen-sync-config.ts",
    "check:sync-config": "vite-node scripts/gen-sync-config.ts -- --check",
    "gen:ambient-accessors": "vite-node scripts/gen-ambient-accessors.ts",
    "check:ambient-accessors": "vite-node scripts/gen-ambient-accessors.ts -- --check",
    "check:rpc-projections": "vite-node scripts/check-rpc-projections.ts",
    "check:no-service-role": "bash scripts/check-no-service-role.sh",
    "audit:attachments-ciphertext": "vite-node scripts/attachments-ciphertext-audit.ts",
    "rls:verify-attachments": "vite-node scripts/attachments-rls-verify.ts",
    "db:runtime": "node scripts/container-runtime.mjs",
    "db:runtime:apple": "node scripts/container-runtime.mjs apple",
    "check:db": "node scripts/check-db.mjs",
    "check": "node scripts/check.mjs",
    "fuzz": "node scripts/fuzz.mjs",
    "agent:server": "node packages/agent-cli/dist/server.js",
    "agent": "node packages/agent-cli/dist/cli.js",
    "agent-dispatch": "node packages/agent-dispatch/dist/daemon.js"
  },
